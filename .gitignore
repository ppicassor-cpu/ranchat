**/keystore.properties
**/release.keystore
**/*.keystore
**/*.jks
# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local
logs/codex-live-view*
logs/cloudflared.exe
logs/manual-remote*
logs/pinggy-test*

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

# Android/Gradle build outputs
**/android/build/
**/android/.gradle/
**/android/.cxx/
